    "topics": [
      {
        "id": "kt01",
        "label": "Gas Equations",
        "type": "list",
        "items": [
          {
            "sub": "General gas relation",
            "latex": "PV = KT \\quad\\text{(K = constant for given sample, T in Kelvin)}"
          },
          {
            "sub": "Perfect gas equation",
            "latex": "PV = \\mu RT \\quad\\text{where }\\mu = \\dfrac{m}{M_0}\\text{ (number of moles)}"
          },
          {
            "sub": "In terms of density",
            "latex": "P = \\dfrac{\\rho RT}{M_0} \\quad\\text{(}\\rho\\text{ = density of gas)}"
          },
          {
            "sub": "Ideal gas at high T, low P",
            "text": "Real gases behave like ideal gas at low pressures and high temperatures"
          },
          {
            "sub": "Dalton's law of partial pressures",
            "latex": "P = P_1 + P_2 + P_3 + \\cdots"
          },
          {
            "sub": "Dalton's law statement",
            "text": "Total pressure of a gas mixture = sum of individual pressures each gas would exert alone at same T"
          }
        ]
      },
      {
        "id": "kt02",
        "label": "Kinetic Theory Formulas",
        "type": "list",
        "items": [
          {
            "sub": "Pressure of ideal gas",
            "latex": "P = \\dfrac{1}{3}nm\\overline{v^2}"
          },
          {
            "sub": "where",
            "text": "n = number density of molecules, m = mass of one molecule, \\(\\overline{v^2}\\) = mean squared speed"
          },
          {
            "sub": "RMS speed",
            "latex": "v_{rms} = \\sqrt{\\overline{v^2}} = \\sqrt{\\dfrac{3k_BT}{m}} = \\sqrt{\\dfrac{3RT}{M_0}}"
          },
          {
            "sub": "Kinetic interpretation of T",
            "latex": "\\dfrac{1}{2}m\\overline{v^2} = \\dfrac{3}{2}k_B T \\quad\\Rightarrow T \\propto \\overline{v^2}"
          },
          {
            "sub": "Translational KE",
            "latex": "E = \\dfrac{3}{2}k_B T \\quad\\text{(per molecule)}"
          },
          {
            "sub": "Mean free path",
            "text": "Average distance covered by a molecule between two successive collisions"
          },
