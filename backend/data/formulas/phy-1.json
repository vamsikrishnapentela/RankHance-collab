[
  {
    "chapter": "Units & Measurements",
    "id": "units",
    "topics": [
      {
        "id": "u01",
        "label": "Physical Quantities",
        "type": "list",
        "items": [
          {
            "sub": "Fundamental quantities",
            "text": "Do not depend on other physical quantities. Eg: length, mass, time, current, temperature"
          },
          {
            "sub": "Derived quantities",
            "text": "Derived from fundamental quantities. Eg: velocity, force, energy"
          },
          {
            "sub": "Fundamental units",
            "text": "Units of fundamental quantities. Eg: kg, m, s"
          },
          {
            "sub": "Derived units",
            "text": "Units of derived quantities. Eg: m/s, m/s², J"
          },
          {
            "sub": "Dimensional formula",
            "text": "Expression representing a physical quantity as mathematical powers of fundamental quantities"
          },
          {
            "sub": "Dimensional constants",
            "text": "Constants with dimensional formula. Eg: Planck's constant h, G (gravitational constant)"
          },
          {
            "sub": "Dimensionless quantities",
            "text": "No dimensional formula. Eg: angle, strain"
          }
        ]
      },
      {
        "id": "u02",
        "label": "Principle of Homogeneity & Uses",
        "type": "list",
        "items": [
          {
            "sub": "Homogeneity",
            "text": "Only quantities with same dimensions can be added, subtracted or equated"
          },
          {
            "sub": "Use 1",
            "text": "Check correctness of an equation"
          },
          {
            "sub": "Use 2",
            "text": "Convert one system of units to another"
          },
          {
            "sub": "Use 3",
            "text": "Derive relations among physical quantities"
          },
          {
            "sub": "Limitation 1",
            "text": "Cannot find dimensionless constants"
          },
          {
            "sub": "Limitation 2",
            "text": "Limited to power-function relations only"
          },
          {
            "sub": "Limitation 3",
            "text": "Not suitable for exponential, logarithmic or trigonometric functions"
          },
          {
            "sub": "Numerical value",
            "latex": "N_1 U_1 = N_2 U_2 \\quad\\text{(N inversely proportional to unit)}"
          }
        ]
      },
      {
        "id": "u03",
        "label": "Errors & Significant Figures",
        "type": "list",
        "items": [
          {
            "sub": "Error",
            "text": "Difference between true value and measured value"
          },
          {
            "sub": "Types of errors",
            "text": "Systematic errors, random errors, gross errors"
          },
          {
            "sub": "True value",
            "text": "Arithmetic mean of large number of repeated measurements"
          },
          {
            "sub": "Accuracy",
            "text": "Closeness of measured value to true value"
          },
          {
            "sub": "Precision",
            "text": "Resolution or limit to which quantity is measured by the instrument"
          },
          {
            "sub": "Significant digits",
            "text": "All definitely known digits + one estimated digit"
          },
          {
            "sub": "1 a.m.u",
            "latex": "1\\,\\text{amu} = 1.66\\times10^{-27}\\,\\text{kg}"
          }
        ]
      }
    ]
  },
  {
    "chapter": "Motion in a Straight Line",
    "id": "motion1d",
    "topics": [
      {
        "id": "m01",
        "label": "Distance, Displacement & Velocity",
        "type": "list",
        "items": [
          {
            "sub": "Distance",
            "text": "Total length of path; scalar"
          },
          {
            "sub": "Displacement",
            "latex": "\\vec{s} = \\text{shortest path with direction; vector; unit: m; } [M^0L^1T^0]"
          },
          {
            "sub": "Speed",
            "latex": "v = \\dfrac{s}{t} \\quad\\text{(scalar)}"
          },
          {
            "sub": "Velocity",
            "latex": "\\vec{v} = \\dfrac{\\vec{s}}{t} \\quad\\text{(vector; m/s; }[M^0L^1T^{-1}]\\text{)}"
          },
          {
            "sub": "Average speed",
            "latex": "v_{avg} = \\dfrac{\\text{total distance}}{\\text{total time}}"
          },
          {
            "sub": "Average velocity (two halves)",
            "latex": "v_{avg} = \\dfrac{2v_1 v_2}{v_1+v_2}"
          },
          {
            "sub": "Instantaneous velocity",
            "latex": "v_{inst} = \\dfrac{dS}{dt}"
          }
        ]
      },
      {
        "id": "m02",
        "label": "Acceleration & Equations of Motion",
        "type": "list",
        "items": [
          {
            "sub": "Acceleration",
            "latex": "a = \\dfrac{v-u}{t} \\quad [M^0L^1T^{-2}]"
          },
          {
            "sub": "v = u + at",
            "latex": "v = u + at"
          },
          {
            "sub": "s = ut + ½at²",
            "latex": "s = ut + \\dfrac{1}{2}at^2"
          },
          {
            "sub": "v² = u² + 2as",
            "latex": "v^2 = u^2 + 2as"
          },
          {
            "sub": "nth second",
            "latex": "s_n = u + a\\left(n - \\dfrac{1}{2}\\right)"
          },
          {
            "sub": "Impulse = Δp",
            "text": "Area under force-time graph gives impulse"
          }
        ]
      },
      {
        "id": "m03",
        "label": "Vertical Motion",
        "type": "list",
        "items": [
          {
            "sub": "Free fall (u=0)",
            "latex": "v = gt,\\; s = \\dfrac{1}{2}gt^2,\\; v^2 = 2gs"
          },
          {
            "sub": "Thrown up",
            "latex": "v = u-gt,\\; h = ut - \\dfrac{1}{2}gt^2,\\; v^2 = u^2 - 2gh"
          },
          {
            "sub": "Max height",
            "latex": "H = \\dfrac{u^2}{2g}"
          },
          {
            "sub": "Time of ascent",
            "latex": "t_a = \\dfrac{u}{g}"
          },
          {
            "sub": "Time of descent",
            "latex": "t_d = \\dfrac{u}{g} = t_a"
          },
          {
            "sub": "Time of flight",
            "latex": "T = \\dfrac{2u}{g}"
          },
          {
            "sub": "Falls from height h",
            "latex": "t = \\sqrt{\\dfrac{2h}{g}}, \\quad v = \\sqrt{2gh}"
          },
          {
            "sub": "Relative velocity (angle θ)",
            "latex": "v_{AB} = \\sqrt{v_A^2 + v_B^2 - 2v_Av_B\\cos\\theta}"
          }
        ]
      }
    ]
  },
  {
    "chapter": "Motion in a Plane",
    "id": "motion2d",
    "topics": [
      {
        "id": "p01",
        "label": "Vectors — Types & Properties",
        "type": "list",
        "items": [
          {
            "sub": "Null vector",
            "text": "Magnitude = 0, direction indeterminate"
          },
          {
            "sub": "Unit vector",
            "latex": "\\hat{A} = \\dfrac{\\vec{A}}{|A|}; \\quad \\hat{i},\\hat{j},\\hat{k}\\text{ along X,Y,Z}"
          },
          {
            "sub": "Position vector",
            "latex": "\\vec{r} = x\\hat{i} + y\\hat{j} + z\\hat{k}"
          },
          {
            "sub": "Magnitude",
            "latex": "|\\vec{A}| = \\sqrt{A_x^2+A_y^2+A_z^2}"
          },
          {
            "sub": "Direction cosines",
            "latex": "\\cos^2\\alpha + \\cos^2\\beta + \\cos^2\\gamma = 1"
          }
        ]
      },
      {
        "id": "p02",
        "label": "Resolution & Parallelogram Law",
        "type": "list",
        "items": [
          {
            "sub": "Horizontal component",
            "latex": "A_x = A\\cos\\theta"
          },
          {
            "sub": "Vertical component",
            "latex": "A_y = A\\sin\\theta"
          },
          {
            "sub": "Resultant magnitude",
            "latex": "R = \\sqrt{A^2+B^2+2AB\\cos\\theta}"
          },
          {
            "sub": "Direction of resultant",
            "latex": "\\tan\\alpha = \\dfrac{B\\sin\\theta}{A+B\\cos\\theta}"
          },
          {
            "sub": "Equal components (θ=45°)",
            "text": "When Ax = Ay, angle with x-axis is 45°"
          }
        ]
      },
      {
        "id": "p03",
        "label": "Projectile Motion",
        "type": "list",
        "items": [
          {
            "sub": "Initial components",
            "latex": "u_x = u\\cos\\theta,\\; u_y = u\\sin\\theta"
          },
          {
            "sub": "Trajectory (parabola)",
            "latex": "y = x\\tan\\theta - \\dfrac{gx^2}{2u^2\\cos^2\\theta}"
          },
          {
            "sub": "Time of flight",
            "latex": "T = \\dfrac{2u\\sin\\theta}{g}"
          },
          {
            "sub": "Maximum height",
            "latex": "H = \\dfrac{u^2\\sin^2\\theta}{2g}"
          },
          {
            "sub": "Horizontal range",
            "latex": "R = \\dfrac{u^2\\sin 2\\theta}{g}"
          },
          {
            "sub": "Max range (θ=45°)",
            "latex": "R_{max} = \\dfrac{u^2}{g}"
          },
          {
            "sub": "Same range angles",
            "text": "θ and (90°−θ) give same range"
          },
          {
            "sub": "Velocity at top",
            "latex": "v_{min} = u\\cos\\theta \\quad\\text{(only horizontal component)}"
          },
          {
            "sub": "Range = 4H",
            "latex": "\\tan\\theta = 4 \\Rightarrow \\theta = \\tan^{-1}(4)"
          }
        ]
      },
      {
        "id": "p04",
        "label": "Dot Product & Cross Product",
        "type": "list",
        "items": [
          {
            "sub": "Dot product",
            "latex": "\\vec{A}\\cdot\\vec{B} = AB\\cos\\theta \\quad\\text{(scalar)}"
          },
          {
            "sub": "Dot product components",
            "latex": "\\vec{A}\\cdot\\vec{B} = A_xB_x+A_yB_y+A_zB_z"
          },
          {
            "sub": "Cross product",
            "latex": "|\\vec{A}\\times\\vec{B}| = AB\\sin\\theta \\quad\\text{(vector ⊥ to both)}"
          },
          {
            "sub": "Cross product = area",
            "text": "Magnitude = area of parallelogram formed by the two vectors"
          },
          {
            "sub": "Parallel vectors",
            "latex": "\\vec{A}\\times\\vec{B} = 0"
          },
          {
            "sub": "Equal dot & cross",
            "text": "If |A·B| = |A×B| then θ = 45°"
          },
          {
            "sub": "Unit vector cross products",
            "latex": "\\hat{i}\\times\\hat{j}=\\hat{k},\\; \\hat{j}\\times\\hat{k}=\\hat{i},\\; \\hat{k}\\times\\hat{i}=\\hat{j}"
          }
        ]
      }
    ]
  },
  {
    "chapter": "Laws of Motion",
    "id": "laws_motion",
    "topics": [
      {
        "id": "lm01",
        "label": "Newton's Laws",
        "type": "list",
        "items": [
          {
            "sub": "1st Law",
            "text": "A body continues in rest or uniform motion unless acted on by external force. Defines inertia and force."
          },
          {
            "sub": "Inertia of rest",
            "text": "Inability to change state of rest by itself"
          },
          {
            "sub": "Inertia of motion",
            "text": "Inability to change state of motion by itself"
          },
          {
            "sub": "Inertia of direction",
            "text": "Inability to change direction of motion by itself"
          },
          {
            "sub": "2nd Law",
            "latex": "F = \\dfrac{dp}{dt} = ma \\quad\\text{(direction of net force)}"
          },
          {
            "sub": "Linear momentum",
            "latex": "p = mv; \\quad 1\\,\\text{N} = 10^5\\,\\text{dyne}"
          },
          {
            "sub": "3rd Law",
            "text": "Action = −Reaction. Acts on different bodies."
          }
        ]
      },
      {
        "id": "lm02",
        "label": "Impulse & Conservation of Momentum",
        "type": "list",
        "items": [
          {
            "sub": "Impulse",
            "latex": "I = F\\times t = \\Delta p = mv - mu"
          },
          {
            "sub": "Impulsive force",
            "text": "Large force for very short time"
          },
          {
            "sub": "Decrease impulsive force",
            "text": "Increase time of impulse (Eg: padding, airbags)"
          },
          {
            "sub": "Conservation of momentum",
            "text": "Total momentum of isolated system is conserved in absence of external force"
          }
        ]
      },
      {
        "id": "lm03",
        "label": "Apparent Weight in Lift",
        "type": "list",
        "items": [
          {
            "sub": "Lift accelerating up",
            "latex": "R = m(g+a) \\quad\\text{(apparent weight increases)}"
          },
          {
            "sub": "Lift accelerating down",
            "latex": "R = m(g-a) \\quad\\text{(apparent weight decreases)}"
          },
          {
            "sub": "Free fall",
            "latex": "R = 0 \\quad\\text{(weightlessness, a=g)}"
          },
          {
            "sub": "Constant velocity",
            "latex": "R = mg \\quad\\text{(a=0)}"
          }
        ]
      },
      {
        "id": "lm04",
        "label": "Friction",
        "type": "list",
        "items": [
          {
            "sub": "Friction law",
            "latex": "f = \\mu R \\quad\\text{(}\\mu\\text{ = coefficient of friction)}"
          },
          {
            "sub": "Coefficient of static friction",
            "latex": "\\mu_s = \\dfrac{f_s}{R}"
          },
          {
            "sub": "Coefficient of kinetic friction",
            "latex": "\\mu_k = \\dfrac{f_k}{R}"
          },
          {
            "sub": "Angle of friction",
            "latex": "\\mu = \\tan\\theta"
          },
          {
            "sub": "Angle of repose",
            "text": "Min angle of inclined plane for body to just start sliding. At repose: f = mg sinα = μ mg cosα"
          },
          {
            "sub": "On horizontal surface",
            "latex": "R = mg"
          },
          {
            "sub": "On inclined surface",
            "latex": "R = mg\\cos\\theta"
          },
          {
            "sub": "Pulling vs pushing",
            "text": "Pulling with inclined force is easier than pushing"
          }
        ]
      }
    ]
  },
  {
    "chapter": "Work, Energy & Power",
    "id": "work_energy",
    "topics": [
      {
        "id": "we01",
        "label": "Work & Power",
        "type": "list",
        "items": [
          {
            "sub": "Work done",
            "latex": "W = F\\cdot S = FS\\cos\\theta"
          },
          {
            "sub": "W > 0",
            "text": "When 0° < θ < 90°"
          },
          {
            "sub": "W = 0",
            "text": "When θ = 90°, or force = 0, or displacement = 0"
          },
          {
            "sub": "W < 0",
            "text": "When 90° < θ < 180°"
          },
          {
            "sub": "Power",
            "latex": "P = \\dfrac{W}{t} = F\\cdot v \\quad\\text{Unit: Watt}"
          },
          {
            "sub": "1 HP",
            "latex": "1\\,\\text{HP} = 746\\,\\text{W}"
          },
          {
            "sub": "Machine gun power",
            "latex": "P = \\dfrac{nmv^2}{2t}"
          }
        ]
      },
      {
        "id": "we02",
        "label": "Kinetic & Potential Energy",
        "type": "list",
        "items": [
          {
            "sub": "Kinetic energy",
            "latex": "KE = \\dfrac{1}{2}mv^2"
          },
          {
            "sub": "KE & momentum",
            "latex": "KE = \\dfrac{p^2}{2m} \\quad\\Rightarrow KE \\propto p^2"
          },
          {
            "sub": "PE at height h",
            "latex": "PE = mgh"
          },
          {
            "sub": "Elastic PE (spring)",
            "latex": "PE = \\dfrac{1}{2}Kx^2 = \\dfrac{F^2}{2K}"
          },
          {
            "sub": "Work-energy theorem",
            "latex": "W = \\Delta KE = \\dfrac{1}{2}mv^2 - \\dfrac{1}{2}mu^2"
          },
          {
            "sub": "1 kWh",
            "latex": "1\\,\\text{kWh} = 3.6\\times10^6\\,\\text{J}"
          }
        ]
      },
      {
        "id": "we03",
        "label": "Conservative Force & Collisions",
        "type": "list",
        "items": [
          {
            "sub": "Conservative force",
            "text": "Work done along closed path = 0; depends only on initial & final position. Eg: gravity"
          },
          {
            "sub": "Non-conservative force",
            "text": "Work done depends on path. Eg: friction"
          },
          {
            "sub": "Elastic collision",
            "text": "Both momentum AND kinetic energy conserved"
          },
          {
            "sub": "Inelastic collision",
            "text": "Only momentum conserved; KE not conserved"
          },
          {
            "sub": "Velocities after elastic collision",
            "latex": "v_1 = \\dfrac{m_1-m_2}{m_1+m_2}u_1 + \\dfrac{2m_2}{m_1+m_2}u_2"
          },
          {
            "sub": "",
            "latex": "v_2 = \\dfrac{2m_1}{m_1+m_2}u_1 + \\dfrac{m_2-m_1}{m_1+m_2}u_2"
          },
          {
            "sub": "Coefficient of restitution",
            "latex": "e = \\dfrac{v_2-v_1}{u_1-u_2} \\quad(e=1:\\text{elastic},\\; e=0:\\text{perfectly inelastic})"
          },
          {
            "sub": "Recoil velocity of rifle",
            "latex": "V = -\\dfrac{mu}{M}"
          },
          {
            "sub": "Ball dropped from h, rebounds",
            "latex": "e = \\sqrt{\\dfrac{h'}{h}} \\quad\\text{(h' = rebound height)}"
          }
        ]
      }
    ]
  },
  {
    "chapter": "System of Particles & Rotational Motion",
    "id": "rotation",
    "topics": [
      {
        "id": "r01",
        "label": "Centre of Mass",
        "type": "list",
        "items": [
          {
            "sub": "Definition",
            "text": "Point where entire mass is supposed to be concentrated"
          },
          {
            "sub": "CM coordinates",
            "latex": "X_{cm} = \\dfrac{\\sum m_i x_i}{\\sum m_i}, \\quad Y_{cm} = \\dfrac{\\sum m_i y_i}{\\sum m_i}"
          },
          {
            "sub": "Two particles",
            "latex": "m_1 r_1 = m_2 r_2 \\quad\\text{(distances from CM)}"
          },
          {
            "sub": "Velocity of CM",
            "latex": "V_{cm} = \\dfrac{\\sum m_i v_i}{M}"
          },
          {
            "sub": "Momentum of CM",
            "latex": "MV_{cm} = \\sum p_i"
          },
          {
            "sub": "No external force",
            "latex": "a_{cm} = 0 \\Rightarrow V_{cm} = \\text{constant}"
          }
        ]
      },
      {
        "id": "r02",
        "label": "Rotational Kinematics",
        "type": "list",
        "items": [
          {
            "sub": "Angular velocity",
            "latex": "\\omega = \\dfrac{d\\theta}{dt} \\quad\\text{Unit: rad/s}"
          },
          {
            "sub": "Linear ↔ angular",
            "latex": "v = \\omega r"
          },
          {
            "sub": "Angular acceleration",
            "latex": "\\alpha = \\dfrac{d\\omega}{dt} \\quad\\text{Unit: rad/s²}"
          },
          {
            "sub": "Rotational equations",
            "latex": "\\omega = \\omega_0 + \\alpha t"
          },
          {
            "sub": "",
            "latex": "\\theta = \\omega_0 t + \\dfrac{1}{2}\\alpha t^2"
          },
          {
            "sub": "",
            "latex": "\\omega^2 = \\omega_0^2 + 2\\alpha\\theta"
          },
          {
            "sub": "nth second",
            "latex": "\\omega_n = \\omega_0 + \\alpha\\left(n-\\dfrac{1}{2}\\right)"
          }
        ]
      },
      {
        "id": "r03",
        "label": "Torque & Angular Momentum",
        "type": "list",
        "items": [
          {
            "sub": "Torque",
            "latex": "\\tau = r\\times F = rF\\sin\\theta"
          },
          {
            "sub": "Torque & angular acceleration",
            "latex": "\\tau = I\\alpha = \\dfrac{dL}{dt}"
          },
          {
            "sub": "Angular momentum",
            "latex": "L = r\\times p = rp\\sin\\theta = I\\omega"
          },
          {
            "sub": "KE of rotation",
            "latex": "KE = \\dfrac{L^2}{2I} = \\dfrac{1}{2}I\\omega^2"
          },
          {
            "sub": "Conservation of L",
            "latex": "\\tau = 0 \\Rightarrow L = I\\omega = \\text{constant}"
          },
          {
            "sub": "",
            "latex": "I_1\\omega_1 = I_2\\omega_2"
          },
          {
            "sub": "Power by torque",
            "latex": "P = \\tau\\omega"
          }
        ]
      },
      {
        "id": "r04",
        "label": "Moment of Inertia",
        "type": "table",
        "table": {
          "headers": [
            "Body",
            "Axis",
            "I"
          ],
          "rows": [
            [
              "Thin circular ring (radius R)",
              "Perpendicular to plane through centre",
              "MR²"
            ],
            [
              "Thin circular ring (radius R)",
              "Diameter",
              "MR²/2"
            ],
            [
              "Thin rod (length L)",
              "⊥ to rod through midpoint",
              "ML²/12"
            ],
            [
              "Circular disc (radius R)",
              "⊥ to disc through centre",
              "MR²/2"
            ],
            [
              "Circular disc (radius R)",
              "Diameter",
              "MR²/4"
            ],
            [
              "Hollow cylinder (radius R)",
              "Geometrical axis",
              "MR²"
            ],
            [
              "Solid cylinder (radius R)",
              "Geometrical axis",
              "MR²/2"
            ],
            [
              "Solid sphere (radius R)",
              "Diameter",
              "2MR²/5"
            ],
            [
              "Hollow sphere (radius R)",
              "Diameter",
              "2MR²/3"
            ]
          ]
        }
      },
      {
        "id": "r05",
        "label": "Theorems of MI & Rolling",
        "type": "list",
        "items": [
          {
            "sub": "Perpendicular axes theorem",
            "latex": "I_z = I_x + I_y \\quad\\text{(plane lamina)}"
          },
          {
            "sub": "Parallel axes theorem",
            "latex": "I = I_{cm} + Md^2"
          },
          {
            "sub": "Rolling down incline — velocity",
            "latex": "v = \\sqrt{\\dfrac{2g\\ell\\sin\\theta}{1+k^2/R^2}} \\quad\\text{(h = \\ell sinθ)}"
          }
        ]
      }
    ]
  },
  {
    "chapter": "Gravitation",
    "id": "gravitation",
    "topics": [
      {
        "id": "g01",
        "label": "Kepler's Laws & Newton's Law",
        "type": "list",
        "items": [
          {
            "sub": "Law of orbits",
            "text": "Planets revolve in elliptical orbits with Sun at one focus"
          },
          {
            "sub": "Law of areas",
            "latex": "\\dfrac{dA}{dt} = \\text{constant} \\quad\\text{(equal areas in equal time)}"
          },
          {
            "sub": "Law of periods",
            "latex": "T^2 \\propto a^3 \\quad\\text{(a = semi-major axis)}"
          },
          {
            "sub": "Newton's law of gravitation",
            "latex": "F = \\dfrac{Gm_1m_2}{r^2}"
          },
          {
            "sub": "G",
