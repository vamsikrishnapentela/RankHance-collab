      "\\(\\dfrac{\\pi}{4}-1\\)",
      "\\(1-\\dfrac{\\pi}{4}\\)",
      "\\(0\\)"
    ],
    "correctIndex": 2,
    "explanation": "\\(\\int_0^{\\pi/4}(\\sec^2x-1)dx=[\\tan x-x]_0^{\\pi/4}=1-\\dfrac{\\pi}{4}\\)",
    "name": "Integral of tan^2(x)"
  },
  {
    "id": "m27_item14",
    "text": "\\(\\displaystyle\\int_0^{\\pi/2}|\\sin t-\\cos t|\\,dt=\\)",
    "options": [
      "\\(2(\\sqrt{2}+1)\\)",
      "\\(2(\\sqrt{2}-1)\\)",
      "\\(\\sqrt{2}+1\\)",
      "\\(\\sqrt{2}-1\\)"
    ],
    "correctIndex": 1,
    "explanation": "\\(\\sin t-\\cos t<0\\) for \\(t<\\pi/4\\) and \\(\\geq0\\) for \\(t\\geq\\pi/4\\).\n\nUsing symmetry: \\(I=2\\int_0^{\\pi/4}(\\cos t-\\sin t)dt=2[\\sin t+\\cos t]_0^{\\pi/4}=2(\\sqrt{2}-1)\\)",
    "name": "Integral of Absolute Value of Trig Function"
  },
  {
    "id": "m27_item15",
    "text": "\\(\\displaystyle\\int_0^{\\pi/2}\\frac{dx}{1+\\tan^{2020}x}=\\)",
    "options": [
